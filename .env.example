# Copy this file to .env for local development with `netlify dev`.
# Never commit your real .env file — it is already listed in .gitignore.

# Required: your Google Gemini API key. Get a free one (no credit card
# required) at https://aistudio.google.com/apikey. Kept server-side only —
# used exclusively inside netlify/functions/generate-tests.ts and never sent
# to the browser.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the Gemini model used for generation.
# LLM_MODEL=gemini-2.5-flash
