# Copy this file to .env for local development with `netlify dev`.
# Never commit your real .env file — it is already listed in .gitignore.

# Required: your Anthropic API key. Kept server-side only; used exclusively
# inside netlify/functions/generate-tests.ts and never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the Claude model used for generation.
# LLM_MODEL=claude-sonnet-5
